# Local-only web server
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DATA_DIR=./data
LOG_LEVEL=INFO

# OpenAI-compatible DeepSeek planner
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=replace-me

# Read-only 1C MCP Toolkit endpoint
MCP_URL=http://127.0.0.1:6003/mcp
MCP_CHANNEL=default

# Local MCP proxy process. The 1C processing and ChatBot must use the same
# host/port/channel. Bind to 0.0.0.0 only when 1C runs on another machine.
MCP_PROXY_HOST=127.0.0.1
MCP_PROXY_PORT=6003
MCP_PROXY_LOG_LEVEL=info
MCP_PROXY_COMMAND_TIMEOUT_SECONDS=11
MCP_PROXY_HEARTBEAT_SECONDS=15

# File export of UT 11.5.27.56; contains Documents/*/Ext/Help/ru.html
UT_CONFIG_DIR=/absolute/path/to/ut/config
AUTO_IMPORT_BUILTIN_SKILLS=true
BUILD_HELP_INDEX_ON_START=true

TARGET_CONFIGURATION_ID=УправлениеТорговлейБазовая
TARGET_RELEASE=11.5.27.56
TARGET_COMPATIBILITY_MODE=8.3.27
