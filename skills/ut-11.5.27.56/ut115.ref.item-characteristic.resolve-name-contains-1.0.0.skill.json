  "operation": {
    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.ref.item-characteristic.resolve-name-contains.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Характеристики.Ссылка КАК Характеристика,\n  Характеристики.Наименование КАК Наименование,\n  &Номенклатура КАК Номенклатура,\n  ПРЕДСТАВЛЕНИЕ(&Номенклатура) КАК НоменклатураНаименование,\n  ИСТИНА КАК Применима\nИЗ Справочник.ХарактеристикиНоменклатуры КАК Характеристики\nГДЕ Характеристики.Владелец = &Номенклатура\n  И Характеристики.Наименование ПОДОБНО &Шаблон СПЕЦСИМВОЛ \"~\"\n  И (НЕ &ЕстьКурсор\n    ИЛИ Характеристики.Наименование > &ИмяКурсора\n    ИЛИ (Характеристики.Наименование = &ИмяКурсора\n      И Характеристики.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Характеристики.Наименование, Характеристики.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [
        {
          "kind": "boolean_literal",
          "statement": 1,
          "value": true,
          "role": "state_filter",
          "occurrences": 1
        }
      ],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
