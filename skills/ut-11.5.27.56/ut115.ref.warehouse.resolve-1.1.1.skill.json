  "operation": {
    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.ref.warehouse.resolve.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Склады.Ссылка КАК Склад,\n  Склады.Наименование КАК Наименование,\n  ПРЕДСТАВЛЕНИЕ(Склады.ТипСклада) КАК ТипСклада,\n  Склады.ТипСклада = ЗНАЧЕНИЕ(Перечисление.ТипыСкладов.РозничныйМагазин) КАК ЭтоРозничный,\n  Склады.Подразделение КАК Подразделение,\n  ПРЕДСТАВЛЕНИЕ(Склады.Подразделение) КАК ПодразделениеНаименование\nИЗ Справочник.Склады КАК Склады\nГДЕ Склады.Наименование ПОДОБНО &Шаблон СПЕЦСИМВОЛ \"~\"\n  И (НЕ &ТолькоРозничные ИЛИ Склады.ТипСклада = ЗНАЧЕНИЕ(Перечисление.ТипыСкладов.РозничныйМагазин))\n  И (&Подразделение ЕСТЬ NULL ИЛИ Склады.Подразделение = &Подразделение)\n  И (НЕ &ЕстьКурсор\n    ИЛИ Склады.Наименование > &ИмяКурсора\n    ИЛИ (Склады.Наименование = &ИмяКурсора\n      И Склады.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Склады.Наименование, Склады.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [
        {
          "kind": "metadata_constant",
          "statement": 1,
          "constant_kind": "enum_member",
          "symbol": "Перечисление.ТипыСкладов.РозничныйМагазин",
          "role": "state_filter",
          "occurrences": 2
        },
        {
          "kind": "null_literal",
          "statement": 1,
          "value": "NULL",
          "role": "absence_filter",
          "occurrences": 1
        }
      ],
