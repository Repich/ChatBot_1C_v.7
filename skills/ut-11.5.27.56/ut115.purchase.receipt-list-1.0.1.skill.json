  "operation": {
    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.purchase.receipt-list.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Документ.Ссылка КАК Поступление,\n  Документ.Номер КАК Номер,\n  Документ.Дата КАК Дата,\n  Документ.Партнер КАК Партнер,\n  ПРЕДСТАВЛЕНИЕ(Документ.Партнер) КАК ПартнерНаименование,\n  Документ.Организация КАК Организация,\n  ПРЕДСТАВЛЕНИЕ(Документ.Организация) КАК ОрганизацияНаименование,\n  Документ.СуммаДокумента КАК СуммаДокумента,\n  Документ.Валюта.Код КАК Валюта\nИЗ Документ.ПриобретениеТоваровУслуг КАК Документ\nГДЕ Документ.Дата >= &НачалоПериода\n  И Документ.Дата < &КонецПериода\n  И (&Номер = \"\" ИЛИ Документ.Номер = &Номер)\n  И (&Партнер ЕСТЬ NULL ИЛИ Документ.Партнер = &Партнер)\n  И (&Организация ЕСТЬ NULL ИЛИ Документ.Организация = &Организация)\n  И (НЕ &ЕстьКурсор\n    ИЛИ Документ.Дата < &ДатаКурсора\n    ИЛИ (Документ.Дата = &ДатаКурсора\n      И Документ.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Документ.Дата УБЫВ, Документ.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [
        {
          "kind": "empty_literal",
          "statement": 1,
          "value": "",
          "role": "absence_filter",
          "occurrences": 1
        },
        {
          "kind": "null_literal",
          "statement": 1,
          "value": "NULL",
          "role": "absence_filter",
          "occurrences": 2
        }
      ],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
    "parameter_bindings": [
      {
        "parameter": "period",
        "query_parameter": "НачалоПериода",
        "encoding": "period_start"
      },
      {
        "parameter": "period",
