  "operation": {
    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.logistics.transfer-list.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Документ.Ссылка КАК Перемещение,\n  Документ.Номер КАК Номер,\n  Документ.Дата КАК Дата,\n  Документ.СкладОтправитель КАК СкладОтправитель,\n  ПРЕДСТАВЛЕНИЕ(Документ.СкладОтправитель) КАК СкладОтправительНаименование,\n  Документ.СкладПолучатель КАК СкладПолучатель,\n  ПРЕДСТАВЛЕНИЕ(Документ.СкладПолучатель) КАК СкладПолучательНаименование,\n  ПРЕДСТАВЛЕНИЕ(Документ.Статус) КАК Статус\nИЗ Документ.ПеремещениеТоваров КАК Документ\nГДЕ Документ.Дата >= &НачалоПериода\n  И Документ.Дата < &КонецПериода\n  И (&Номер = \"\" ИЛИ Документ.Номер = &Номер)\n  И (&СкладОтправитель ЕСТЬ NULL ИЛИ Документ.СкладОтправитель = &СкладОтправитель)\n  И (&СкладПолучатель ЕСТЬ NULL ИЛИ Документ.СкладПолучатель = &СкладПолучатель)\n  И (НЕ &ЕстьКурсор\n    ИЛИ Документ.Дата < &ДатаКурсора\n    ИЛИ (Документ.Дата = &ДатаКурсора\n      И Документ.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Документ.Дата УБЫВ, Документ.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [
        {
          "kind": "empty_literal",
          "statement": 1,
          "value": "",
          "role": "absence_filter",
          "occurrences": 1
        },
        {
          "kind": "null_literal",
          "statement": 1,
          "value": "NULL",
          "role": "absence_filter",
          "occurrences": 2
        }
      ],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
    "parameter_bindings": [
      {
        "parameter": "period",
        "query_parameter": "НачалоПериода",
        "encoding": "period_start"
      },
