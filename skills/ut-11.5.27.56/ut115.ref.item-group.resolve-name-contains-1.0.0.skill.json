    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.ref.item-group.resolve-name-contains.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Группы.Ссылка КАК Группа,\n  Группы.Наименование КАК Наименование,\n  Группы.Код КАК Код,\n  Группы.ЭтоГруппа КАК ЭтоГруппа\nИЗ Справочник.Номенклатура КАК Группы\nГДЕ Группы.ЭтоГруппа\n  И Группы.Наименование ПОДОБНО &Шаблон СПЕЦСИМВОЛ \"~\"\n  И (НЕ &ЕстьКурсор\n    ИЛИ Группы.Наименование > &ИмяКурсора\n    ИЛИ (Группы.Наименование = &ИмяКурсора\n      И Группы.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Группы.Наименование, Группы.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
