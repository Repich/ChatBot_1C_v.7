    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.ref.customer.resolve-inn-exact.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Партнеры.Ссылка КАК Клиент,\n  Партнеры.Наименование КАК Наименование,\n  Партнеры.Код КАК Код,\n  Партнеры.Клиент КАК ЭтоКлиент,\n  Партнеры.Поставщик КАК ЭтоПоставщик,\n  &ИНН КАК ИНН\nИЗ Справочник.Партнеры КАК Партнеры\nГДЕ Партнеры.Клиент\n  И Партнеры.Ссылка В (ВЫБРАТЬ Контрагенты.Партнер ИЗ Справочник.Контрагенты КАК Контрагенты ГДЕ Контрагенты.ИНН = &ИНН)\n  И (НЕ &ЕстьКурсор\n    ИЛИ Партнеры.Наименование > &ИмяКурсора\n    ИЛИ (Партнеры.Наименование = &ИмяКурсора\n      И Партнеры.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Партнеры.Наименование, Партнеры.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
