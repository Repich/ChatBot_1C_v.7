    "query_template": {
      "template_id": "ut115.ref.inventory-purpose.resolve-name-contains.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Назначения.Ссылка КАК Назначение,\n  Назначения.Наименование КАК Наименование,\n  ПРЕДСТАВЛЕНИЕ(Назначения.ТипНазначения) КАК ТипНазначения,\n  ПРЕДСТАВЛЕНИЕ(Назначения.Партнер) КАК Партнер,\n  ПРЕДСТАВЛЕНИЕ(Назначения.Договор) КАК Договор,\n  ПРЕДСТАВЛЕНИЕ(Назначения.Заказ) КАК Заказ,\n  ПРЕДСТАВЛЕНИЕ(Назначения.НаправлениеДеятельности) КАК Направление\nИЗ Справочник.Назначения КАК Назначения\nГДЕ Назначения.Наименование ПОДОБНО &Шаблон СПЕЦСИМВОЛ \"~\"\n  И (НЕ &ЕстьКурсор\n    ИЛИ Назначения.Наименование > &ИмяКурсора\n    ИЛИ (Назначения.Наименование = &ИмяКурсора\n      И Назначения.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Назначения.Наименование, Назначения.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
