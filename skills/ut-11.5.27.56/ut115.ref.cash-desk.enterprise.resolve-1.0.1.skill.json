  "operation": {
    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.ref.cash-desk.enterprise.resolve.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Кассы.Ссылка КАК Касса,\n  Кассы.Наименование КАК Наименование,\n  &ВидКассы КАК ВидКассы,\n  Кассы.Владелец КАК Организация,\n  ПРЕДСТАВЛЕНИЕ(Кассы.Владелец) КАК ОрганизацияНаименование,\n  Кассы.ВалютаДенежныхСредств КАК Валюта,\n  Кассы.ВалютаДенежныхСредств.Код КАК КодВалюты\nИЗ Справочник.Кассы КАК Кассы\nГДЕ Кассы.Владелец = &Организация\n  И Кассы.Наименование ПОДОБНО &Шаблон СПЕЦСИМВОЛ \"~\"\n  И (НЕ &ЕстьКурсор\n    ИЛИ Кассы.Наименование > &ИмяКурсора\n    ИЛИ (Кассы.Наименование = &ИмяКурсора\n      И Кассы.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Кассы.Наименование, Кассы.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
