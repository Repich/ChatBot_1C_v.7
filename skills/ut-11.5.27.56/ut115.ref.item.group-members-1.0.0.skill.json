  "operation": {
    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.ref.item.group-members.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Номенклатура.Ссылка КАК Номенклатура,\n  Номенклатура.Наименование КАК Наименование,\n  Номенклатура.Код КАК Код,\n  Номенклатура.Родитель КАК Родитель,\n  &Группа КАК ВыбраннаяГруппа\nИЗ Справочник.Номенклатура КАК Номенклатура\nГДЕ НЕ Номенклатура.ЭтоГруппа\n  И ((&ВключаяПодгруппы И Номенклатура.Родитель В ИЕРАРХИИ (&Группа))\n    ИЛИ (НЕ &ВключаяПодгруппы И Номенклатура.Родитель = &Группа))\n  И (НЕ &ЕстьКурсор\n    ИЛИ Номенклатура.Наименование > &ИмяКурсора\n    ИЛИ (Номенклатура.Наименование = &ИмяКурсора\n      И Номенклатура.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Номенклатура.Наименование, Номенклатура.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
