    "read_only": true,
    "query_template": {
      "template_id": "ut115.ref.organization.resolve-inn-exact.v1",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Организации.Ссылка КАК Организация,\n  Организации.Наименование КАК Наименование,\n  Организации.НаименованиеПолное КАК НаименованиеПолное,\n  Организации.ИНН КАК ИНН,\n  Организации.КПП КАК КПП,\n  ИСТИНА КАК Собственная\nИЗ Справочник.Организации КАК Организации\nГДЕ Организации.ИНН = &ИНН\n  И (НЕ &ЕстьКурсор\n    ИЛИ Организации.Наименование > &ИмяКурсора\n    ИЛИ (Организации.Наименование = &ИмяКурсора\n      И Организации.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Организации.Наименование, Организации.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [
        {
          "kind": "boolean_literal",
          "statement": 1,
          "value": true,
          "role": "state_filter",
          "occurrences": 1
        }
      ],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
