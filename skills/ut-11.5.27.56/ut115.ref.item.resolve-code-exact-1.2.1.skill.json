  "operation": {
    "kind": "data_query",
    "tool": "execute_query",
    "read_only": true,
    "query_template": {
      "template_id": "ut115.ref.item.resolve-code-exact.v2",
      "language": "1c-query",
      "text": "ВЫБРАТЬ\n  Номенклатура.Ссылка КАК Номенклатура,\n  Номенклатура.Код КАК Код,\n  Номенклатура.Артикул КАК Артикул,\n  Номенклатура.Наименование КАК Наименование,\n  НЕ Номенклатура.ЭтоГруппа КАК ЭтоТовар\nИЗ Справочник.Номенклатура КАК Номенклатура\nГДЕ НЕ Номенклатура.ЭтоГруппа\n  И Номенклатура.Код = &Код\n  И (НЕ &ЕстьКурсор\n    ИЛИ Номенклатура.Наименование > &ИмяКурсора\n    ИЛИ (Номенклатура.Наименование = &ИмяКурсора\n      И Номенклатура.Ссылка > &СсылкаКурсора))\nУПОРЯДОЧИТЬ ПО Номенклатура.Наименование, Номенклатура.Ссылка",
      "execution": {
        "kind": "single_select",
        "statement_count": 1,
        "final_statement": 1
      },
      "invariant_constants": [],
      "include_schema": true,
      "mcp_limit": {
        "default": 20,
        "maximum": 1000
      }
    },
    "parameter_bindings": [
      {
        "parameter": "catalog_code",
        "query_parameter": "Код",
        "encoding": "string"
      }
    ],
