        "fact_id": "item.ref",
        "accepted_mcp_types": [
          "СправочникСсылка.Номенклатура"
        ],
        "converter": "object_ref"
      },
      {
        "column": "Код",
        "fact_id": "item.code",
        "accepted_mcp_types": [
          "Строка"
        ],
        "converter": "string"
      },
      {
